# Mot de passe du compte de service des agents (cree cote backend).
# Copier ce fichier en .env (gitignore) sur chaque VM et renseigner la valeur :
#   cp .env.example .env
# Le .env n'est jamais commite ni synchronise : il reste local a chaque machine.
SIEM_AGENT_PASSWORD=remplace_par_le_mot_de_passe_du_compte_agent
